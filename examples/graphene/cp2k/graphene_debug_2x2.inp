&GLOBAL
  PROJECT graphene_debug
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS

    &MGRID
      CUTOFF 200
      REL_CUTOFF 30
    &END MGRID

    &QS
      EPS_DEFAULT 1.0E-9
    &END QS

    &SCF
      EPS_SCF 1.0E-6
      MAX_SCF 60
      ADDED_MOS 8
      &DIAGONALIZATION
      &END DIAGONALIZATION
      &SMEAR
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE 300
      &END SMEAR
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        NBROYDEN 8
      &END MIXING
    &END SCF

    # A malha 3x3 da supercelula equivale a 6x6 na celula primitiva.
    &KPOINTS
      SCHEME MONKHORST-PACK 3 3 1
      FULL_GRID T
      SYMMETRY F
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    # H(R) e S(R) usam o mesmo prefixo. Os rotulos KS/S nos nomes dos
    # arquivos permitem que o conversor os separe automaticamente.
    &PRINT
      &KS_CSR_WRITE ON
        FILENAME ./graphene_debug
        REAL_SPACE T
        BINARY F
        UPPER_TRIANGULAR F
        THRESHOLD 1.0E-14
      &END KS_CSR_WRITE
      &S_CSR_WRITE ON
        FILENAME ./graphene_debug
        REAL_SPACE T
        BINARY F
        UPPER_TRIANGULAR F
        THRESHOLD 1.0E-14
      &END S_CSR_WRITE
    &END PRINT
  &END DFT

  &SUBSYS
    &CELL
      A 4.920000000 0.000000000 0.000000000
      B 2.460000000 4.260844986 0.000000000
      C 0.000000000 0.000000000 15.000000000
      PERIODIC XYZ
    &END CELL

    &COORD
      C 0.000000000 0.000000000 7.500000000
      C 0.000000000 1.420281662 7.500000000
      C 2.460000000 0.000000000 7.500000000
      C 2.460000000 1.420281662 7.500000000
      C 1.230000000 2.130422493 7.500000000
      C 1.230000000 3.550704155 7.500000000
      C 3.690000000 2.130422493 7.500000000
      C 3.690000000 3.550704155 7.500000000
    &END COORD

    &KIND C
      ELEMENT C
      BASIS_SET SZV-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
