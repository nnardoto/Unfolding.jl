&GLOBAL
  PROJECT graphene_debug_pc
  RUN_TYPE ENERGY
  PRINT_LEVEL MEDIUM
&END GLOBAL

&FORCE_EVAL
  METHOD QUICKSTEP
  &DFT
    BASIS_SET_FILE_NAME BASIS_MOLOPT
    POTENTIAL_FILE_NAME GTH_POTENTIALS

    &MGRID
      CUTOFF 200
      REL_CUTOFF 30
    &END MGRID

    &QS
      EPS_DEFAULT 1.0E-9
    &END QS

    &SCF
      EPS_SCF 1.0E-6
      MAX_SCF 60
      ADDED_MOS 4
      &DIAGONALIZATION
      &END DIAGONALIZATION
      &SMEAR
        METHOD FERMI_DIRAC
        ELECTRONIC_TEMPERATURE 300
      &END SMEAR
      &MIXING
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        NBROYDEN 8
      &END MIXING
    &END SCF

    # Equivalente a malha 3x3x1 da supercelula 2x2.
    &KPOINTS
      SCHEME MONKHORST-PACK 6 6 1
      FULL_GRID T
      SYMMETRY F
      WAVEFUNCTIONS COMPLEX
    &END KPOINTS

    &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
    &END XC

    &PRINT
      &KS_CSR_WRITE ON
        FILENAME ./graphene_debug_pc
        REAL_SPACE T
        BINARY F
        UPPER_TRIANGULAR F
        THRESHOLD 1.0E-14
      &END KS_CSR_WRITE
      &S_CSR_WRITE ON
        FILENAME ./graphene_debug_pc
        REAL_SPACE T
        BINARY F
        UPPER_TRIANGULAR F
        THRESHOLD 1.0E-14
      &END S_CSR_WRITE
    &END PRINT
  &END DFT

  &SUBSYS
    &CELL
      A 2.460000000 0.000000000 0.000000000
      B 1.230000000 2.130422493 0.000000000
      C 0.000000000 0.000000000 15.000000000
      PERIODIC XYZ
    &END CELL

    &COORD
      C 0.000000000 0.000000000 7.500000000
      C 0.000000000 1.420281662 7.500000000
    &END COORD

    &KIND C
      ELEMENT C
      BASIS_SET SZV-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND
  &END SUBSYS
&END FORCE_EVAL
